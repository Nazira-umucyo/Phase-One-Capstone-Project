<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.AccountController"
            prefWidth="700" prefHeight="500"
            style="-fx-background-color: #F5F7FA;">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #2C3E50; -fx-padding: 15 25;">
            <Button text="←" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand; -fx-padding: 0 10 0 0;"/>
            <Text text="IgirePay" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #F39C12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Text text="Account Management"
                  style="-fx-font-size: 13; -fx-fill: white;"/>
        </HBox>
    </top>

    <!-- Sidebar -->
    <left>
        <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="ACCOUNT MENU"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11; -fx-padding: 0 0 10 5;"/>
            <Button text="  💳  Create Wallet" maxWidth="180"
                    onAction="#handleCreateWallet"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="  🏦  Create Savings" maxWidth="180"
                    onAction="#handleCreateSavings"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="  💰  View Balance" maxWidth="180"
                    onAction="#handleViewBalance"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="  🗑️  Delete Account" maxWidth="180"
                    onAction="#handleDeleteAccount"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15"
              style="-fx-padding: 30; -fx-background-color: #F5F7FA;">

            <!-- Create Account Section -->
            <VBox fx:id="createSection" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text fx:id="createTitle" text="Create Account"
                      style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <Label fx:id="createMessage" text="Select Wallet or Savings from the sidebar."
                       style="-fx-font-size: 13; -fx-text-fill: #7F8C8D;"/>
            </VBox>

            <VBox fx:id="balanceSection" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text text="View Balance"
                      style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <TextField fx:id="accountIdField" promptText="Enter Account ID"
                           style="-fx-padding: 10; -fx-background-radius: 6;"/>
                <Button text="Check Balance" onAction="#handleCheckBalance"
                        style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
                <Label fx:id="balanceLabel" text="" style="-fx-font-size: 13;"/>
            </VBox>

            <VBox fx:id="deleteSection" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text text="Delete Account"
                      style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <TextField fx:id="deleteAccountIdField" promptText="Enter Account ID"
                           style="-fx-padding: 10; -fx-background-radius: 6;"/>
                <Button text="Delete Account" onAction="#handleConfirmDelete"
                        style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </VBox>

            <Label fx:id="messageLabel" text="" style="-fx-text-fill: #E74C3C;"/>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-padding: 10; -fx-background-color: #ECF0F1;">
            <Label text="© 2026 IgirePay Technologies Ltd."
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.DashboardController"
            prefWidth="700" prefHeight="500"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #2C3E50; -fx-padding: 15 25;">
            <Text text="IgirePay" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #F39C12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Text fx:id="welcomeText" text="Welcome!"
                  style="-fx-font-size: 13; -fx-fill: white;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 20; -fx-min-width: 200;">

            <Label text="MAIN MENU"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11; -fx-padding: 0 0 10 5;"/>

            <Button text="  👤  Customer Management" maxWidth="180"
                    onAction="#handleCustomerManagement"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="  🏦  Account Management" maxWidth="180"
                    onAction="#handleAccountManagement"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="  💸  Transactions" maxWidth="180"
                    onAction="#handleTransactionManagement"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="  📊  Reports" maxWidth="180"
                    onAction="#handleReports"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Button text="  🔑  Change PIN" maxWidth="180"
                    onAction="#handleChangePin"
                    style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

            <Button text="  🚪  Logout" maxWidth="180"
                    onAction="#handleLogout"
                    style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>

        </VBox>
    </left>

    <center>
        <VBox alignment="CENTER" spacing="20"
              style="-fx-padding: 40; -fx-background-color: #F5F7FA;">

            <Text text="Welcome to IgirePay"
                  style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
            <Text text="Select an option from the sidebar to get started."
                  style="-fx-font-size: 13; -fx-fill: #7F8C8D;"/>

            <GridPane hgap="20" vgap="20" alignment="CENTER">

                <VBox alignment="CENTER" spacing="5" prefWidth="130" prefHeight="100"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;"
                      GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Text text="👤" style="-fx-font-size: 28;"/>
                    <Text text="Customers" style="-fx-font-size: 12; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" prefWidth="130" prefHeight="100"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;"
                      GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Text text="🏦" style="-fx-font-size: 28;"/>
                    <Text text="Accounts" style="-fx-font-size: 12; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" prefWidth="130" prefHeight="100"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;"
                      GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Text text="💸" style="-fx-font-size: 28;"/>
                    <Text text="Transactions" style="-fx-font-size: 12; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
                </VBox>

                <VBox alignment="CENTER" spacing="5" prefWidth="130" prefHeight="100"
                      style="-fx-background-color: white; -fx-background-radius: 8; -fx-padding: 15;"
                      GridPane.columnIndex="3" GridPane.rowIndex="0">
                    <Text text="📊" style="-fx-font-size: 28;"/>
                    <Text text="Reports" style="-fx-font-size: 12; -fx-fill: #2C3E50; -fx-font-weight: bold;"/>
                </VBox>

            </GridPane>

            <Label fx:id="messageLabel" text="" style="-fx-text-fill: #E74C3C;"/>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-padding: 10; -fx-background-color: #ECF0F1;">
            <Label text="© 2026 IgirePay Technologies Ltd."
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
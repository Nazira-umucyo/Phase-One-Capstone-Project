<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.LoginController"
            prefWidth="700" prefHeight="500"
            style="-fx-background-color: #F5F7FA;">

    <!-- Left Panel -->
    <left>
        <VBox alignment="CENTER" spacing="10"
              style="-fx-background-color: #2C3E50; -fx-padding: 40; -fx-min-width: 300;">
            <Text text="IgirePay" style="-fx-font-size: 36; -fx-font-weight: bold; -fx-fill: #F39C12;"/>
            <Text text="Digital Wallet System"
                  style="-fx-font-size: 13; -fx-fill: white;"/>
            <Text text="Fast. Secure. Reliable."
                  style="-fx-font-size: 11; -fx-fill: #95A5A6;"/>
        </VBox>
    </left>

    <!-- Right Panel - Login Form -->
    <center>
        <VBox alignment="CENTER" spacing="15"
              style="-fx-padding: 40; -fx-background-color: #F5F7FA;">

            <Text text="Welcome Back!" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
            <Text text="Login to your account"
                  style="-fx-font-size: 12; -fx-fill: #7F8C8D;"/>

            <VBox spacing="5" maxWidth="280">
                <Label text="Phone Number" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                <TextField fx:id="phoneField" promptText="Enter phone number"
                           style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #BDC3C7; -fx-border-radius: 6;"/>
            </VBox>

            <VBox spacing="5" maxWidth="280">
                <Label text="PIN" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                <PasswordField fx:id="pinField" promptText="Enter PIN"
                               style="-fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #BDC3C7; -fx-border-radius: 6;"/>
            </VBox>

            <Button text="Login" maxWidth="280"
                    onAction="#handleLogin"
                    style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>

            <HBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?"
                       style="-fx-text-fill: #7F8C8D;"/>
                <Button text="Register"
                        onAction="#handleRegister"
                        style="-fx-background-color: transparent; -fx-text-fill: #2980B9; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </HBox>

            <Label fx:id="messageLabel" text=""
                   style="-fx-text-fill: #E74C3C;"/>

        </VBox>
    </center>

</BorderPane>
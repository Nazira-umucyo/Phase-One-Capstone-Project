<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.lab3.controller.ChangepinController"
            prefWidth="700" prefHeight="500"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #2C3E50; -fx-padding: 15 25;">
            <Button text="←" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand; -fx-padding: 0 10 0 0;"/>
            <Text text="IgirePay" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #F39C12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Text text="Change PIN" style="-fx-font-size: 13; -fx-fill: white;"/>
        </HBox>
    </top>

    <!-- Main Content -->
    <center>
        <VBox alignment="CENTER" spacing="15"
              style="-fx-padding: 40; -fx-background-color: #F5F7FA;">

            <VBox spacing="15" maxWidth="350"
                  style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 8;">

                <Text text="Change PIN"
                      style="-fx-font-size: 20; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <Text text="Enter your old PIN and choose a new one."
                      style="-fx-font-size: 12; -fx-fill: #7F8C8D;"/>

                <VBox spacing="5">
                    <Label text="Old PIN" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="oldPinField" promptText="Enter old PIN"
                                   style="-fx-padding: 10; -fx-background-radius: 6;"/>
                </VBox>

                <VBox spacing="5">
                    <Label text="New PIN" style="-fx-text-fill: #2C3E50; -fx-font-weight: bold;"/>
                    <PasswordField fx:id="newPinField" promptText="Enter new PIN"
                                   style="-fx-padding: 10; -fx-background-radius: 6;"/>
                </VBox>

                <Button text="Change PIN" maxWidth="290"
                        onAction="#handleChangePin"
                        style="-fx-background-color: #27AE60; -fx-text-fill: white; -fx-font-size: 14; -fx-padding: 12; -fx-background-radius: 6; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Button text="Back to Dashboard" maxWidth="290"
                        onAction="#handleBack"
                        style="-fx-background-color: transparent; -fx-text-fill: #2980B9; -fx-cursor: hand; -fx-font-weight: bold;"/>

                <Label fx:id="messageLabel" text=""/>

            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-padding: 10; -fx-background-color: #ECF0F1;">
            <Label text="© 2026 IgirePay Technologies Ltd."
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>
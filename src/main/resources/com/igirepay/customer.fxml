<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.igirepay.CustomerController"
            prefWidth="700" prefHeight="500"
            style="-fx-background-color: #F5F7FA;">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="20"
              style="-fx-background-color: #2C3E50; -fx-padding: 15 25;">
            <Button text="←" onAction="#handleBack"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18; -fx-cursor: hand; -fx-padding: 0 10 0 0;"/>
            <Text text="IgirePay" style="-fx-font-size: 22; -fx-font-weight: bold; -fx-fill: #F39C12;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Text text="Customer Management"
                  style="-fx-font-size: 13; -fx-fill: white;"/>
        </HBox>
    </top>

    <left>
        <VBox spacing="5" style="-fx-background-color: #34495E; -fx-padding: 20; -fx-min-width: 200;">
            <Label text="CUSTOMER MENU"
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11; -fx-padding: 0 0 10 5;"/>
            <Button text="  👤  View Profile" maxWidth="180"
                    onAction="#handleViewProfile"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="  ✏️  Update Information" maxWidth="180"
                    onAction="#handleUpdateInfo"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            <Button text="  🏦  View Accounts" maxWidth="180"
                    onAction="#handleViewAccounts"
                    style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand; -fx-alignment: CENTER_LEFT;"/>
            </VBox>
    </left>

    <center>
        <VBox alignment="TOP_CENTER" spacing="15"
              style="-fx-padding: 30; -fx-background-color: #F5F7FA;">

            <!-- Profile Section -->
            <VBox fx:id="profileSection" spacing="10"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text text="My Profile" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <Label fx:id="nameLabel" text="" style="-fx-font-size: 13;"/>
                <Label fx:id="emailLabel" text="" style="-fx-font-size: 13;"/>
                <Label fx:id="phoneLabel" text="" style="-fx-font-size: 13;"/>
            </VBox>

            <!-- Update Section -->
            <VBox fx:id="updateSection" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text text="Update Information" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <TextField fx:id="fullNameField" promptText="Full Name"
                           style="-fx-padding: 10; -fx-background-radius: 6;"/>
                <TextField fx:id="emailField" promptText="Email"
                           style="-fx-padding: 10; -fx-background-radius: 6;"/>
                <TextField fx:id="phoneField" promptText="Phone Number"
                           style="-fx-padding: 10; -fx-background-radius: 6;"/>
                <Button text="Save Changes" onAction="#handleSaveInfo"
                        style="-fx-background-color: #2980B9; -fx-text-fill: white; -fx-padding: 10; -fx-background-radius: 6; -fx-cursor: hand;"/>
            </VBox>

            <VBox fx:id="accountsSection" spacing="10" visible="false" managed="false"
                  style="-fx-background-color: white; -fx-padding: 20; -fx-background-radius: 8;">
                <Text text="My Accounts" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-fill: #2C3E50;"/>
                <Label fx:id="accountsLabel" text="" style="-fx-font-size: 13;"/>
            </VBox>

            <Label fx:id="messageLabel" text="" style="-fx-text-fill: #E74C3C;"/>

        </VBox>
    </center>

    <bottom>
        <HBox alignment="CENTER"
              style="-fx-padding: 10; -fx-background-color: #ECF0F1;">
            <Label text="© 2026 IgirePay Technologies Ltd."
                   style="-fx-text-fill: #95A5A6; -fx-font-size: 11;"/>
        </HBox>
    </bottom>

</BorderPane>